{
  "permissions": {
    "allow": [
      "WebSearch",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(ls:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(find:*)",
      "Bash(cat:*)",
      "Bash(python3:*)",
      "Bash(cp:*)",
      "Bash(cd:*)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [],
  "hooks": {
    "SessionStart": [
      {
        "matcher": "clear",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/skills/mem/references/rotate.py"
          }
        ]
      }
    ]
  }
}
